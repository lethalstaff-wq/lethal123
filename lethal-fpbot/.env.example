# Telegram Bot
BOT_TOKEN=put_your_telegram_bot_token_here

# Через запятую — Telegram ID админов
ADMIN_IDS=

# Путь к SQLite файлу (опционально)
# DB_PATH=lethal_fpbot.db

# Fernet (urlsafe-base64) ключ для шифрования паролей.
# Если не задан — будет создан автоматически в .secret_key
# ENCRYPTION_KEY=

# Ключ Claude API для ИИ-фич (Pro). Без него ИИ кнопки покажут заглушку.
# ANTHROPIC_API_KEY=
